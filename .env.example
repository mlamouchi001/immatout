# ============================================
# Database
# ============================================
DATABASE_URL="postgresql://immatout:immatout@localhost:5434/immatout?schema=public"

# ============================================
# SIV (Système d'Immatriculation des Véhicules) Provider
# ============================================
# Options: "mock" | "apiplaqueimmatriculation" | "autoways" | "apiparticulier"
SIV_API_PROVIDER="mock"
SIV_API_URL=""
SIV_API_KEY=""

# Cache duration for SIV lookups (seconds, default 30 days)
SIV_CACHE_TTL_SECONDS=2592000

# ============================================
# Admin / Protected routes
# ============================================
ADMIN_USER="admin"
ADMIN_PASSWORD="change-me-in-prod"

# ============================================
# App
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ============================================
# Analytics (optional, Plausible - RGPD-friendly)
# ============================================
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
