// Immatout database schema.
// Stores reference scales and ingested vehicle-identification data.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Reference scales (mirrored from packages/data JSON for query flexibility).
// ---------------------------------------------------------------------------

model RegionScale {
  id                  Int      @id @default(autoincrement())
  scaleYear           Int
  regionCode          String   @db.VarChar(3)
  regionName          String
  perCvRateCents      Int // stored in cents to avoid float drift
  energyCoefficients  Json // record<EnergyType, number>
  idfmSurchargeCents  Int      @default(0) // only non-zero for IDF
  publishedAt         DateTime
  source              String

  @@unique([scaleYear, regionCode])
  @@index([scaleYear])
}

model Co2MalusScale {
  id                     Int      @id @default(autoincrement())
  scaleYear              Int      @unique
  globalMalusCapCents    BigInt
  grid                   Json // [{ co2GPerKm, amountCents }]
  source                 String
  importedAt             DateTime @default(now())
}

model WeightMalusScale {
  id                     Int      @id @default(autoincrement())
  scaleYear              Int      @unique
  triggerKg              Int
  tranches               Json
  abatements             Json
  evApplicable           Boolean
  source                 String
  importedAt             DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Legacy flat vehicle reference (kept for back-compat; superseded by
// CatalogMake / CatalogModel / CatalogTrim below).
// ---------------------------------------------------------------------------

model VehicleModel {
  id                     Int      @id @default(autoincrement())
  cnit                   String?  @unique
  make                   String
  model                  String
  variant                String?
  year                   Int
  energy                 String
  fiscalHorsepower       Int
  co2WltpGPerKm          Int?
  massInRunningOrderKg   Int?
  cylinderCapacityCm3    Int?
  enginePowerKw          Int?
  source                 String // "ADEME" | "EEA"
  importedAt             DateTime @default(now())

  @@index([make, model, year])
}

// ---------------------------------------------------------------------------
// Vehicle catalog (ADEME + EEA merged, queried by the model-picker UI).
// ---------------------------------------------------------------------------

model CatalogMake {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  sources   String[] // ["ademe","eea","vpic"]
  models    CatalogModel[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model CatalogModel {
  id         Int           @id @default(autoincrement())
  makeId     Int
  make       CatalogMake   @relation(fields: [makeId], references: [id], onDelete: Cascade)
  name       String
  slug       String
  trims      CatalogTrim[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([makeId, name])
  @@index([name])
}

model CatalogTrim {
  id              Int          @id @default(autoincrement())
  modelId         Int
  model           CatalogModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  naturalKey      String       @unique // make-model-variant-energy-power+displacement hash
  label           String
  energy          String       // EnergyCode: ES, GO, EE, EH, GH, GL, GN, H2, OTHER
  fiscalCv        Int
  fiscalCvApprox  Boolean      @default(false) // true when derived from CO2+kW formula
  co2GPerKm       Int?
  weightKg        Int?
  powerKw         Float?
  displacementCc  Int?
  bodyType        String?
  marketYear      Int?         // year of data snapshot (ADEME latest, EEA 2023, etc.)
  source          String       // "ademe" | "eea"
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([modelId])
  @@index([energy, fiscalCv])
  @@index([marketYear])
}

model CatalogSeedState {
  id             Int      @id @default(autoincrement())
  source         String   @unique // "ademe" | "eea"
  lastSeededAt   DateTime
  rowCount       Int
  durationMs     Int
  version        String   // e.g. "2026-03-15" ADEME snapshot, "2023Fv28" EEA
}

// ---------------------------------------------------------------------------
// Cache for SIV provider lookups (F1 requirement: 30-day cache).
// ---------------------------------------------------------------------------

model SivLookupCache {
  id             Int      @id @default(autoincrement())
  plate          String   @unique
  provider       String
  payload        Json
  fetchedAt      DateTime @default(now())
  expiresAt      DateTime

  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// Calculation audit trail (for reproducibility & stats).
// ---------------------------------------------------------------------------

model CalculationLog {
  id               String   @id @default(cuid())
  engineVersion    String
  scaleVersion     String
  vehicleCase      String
  regionCode       String
  input            Json
  output           Json
  totalCents       Int
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([regionCode, vehicleCase])
}
